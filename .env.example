# Shop Meraj — root-level environment for `docker compose up`
# Copy to `.env` and adjust. Empty values fall back to defaults baked into compose.yaml.

# === Project ===
PROJECT_NAME=Shop Meraj
ENVIRONMENT=local
SECRET_KEY=changethis

# === Database ===
POSTGRES_DB=shop_meraj
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# === Admin bootstrap ===
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# === Frontend ===
# Public URL the browser hits — baked into the JS bundle at build time.
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# === Telegram (optional — without these the backend creates orders silently) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# === Email (optional) ===
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# === Observability (optional) ===
SENTRY_DSN=

# === Catalog seed (optional) ===
# Path inside the backend container. The image already ships /app/seed/shop_seed.example.json.
# Leave empty to use the built-in default seed (3 categories, 10 delivery places, 4 products).
SHOP_SEED_FILE=
